rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net: Default Deny All
    match /{document=**} {
      allow read, write: if false;
    }
    
    // 2. Global Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // 3. Validation Blueprints (Anti-Update-Gap)
    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.message is string && data.message.size() > 0 && data.message.size() <= 5000
        && data.createdAt == request.time;
    }
    
    function isValidTestimonial(data) {
      return data.keys().hasAll(['userId', 'userName', 'userPhoto', 'text', 'createdAt'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() > 0 && data.userName.size() <= 100
        && (data.userPhoto == null || (data.userPhoto is string && data.userPhoto.size() <= 500))
        && data.text is string && data.text.size() > 0 && data.text.size() <= 1000
        && data.createdAt == request.time;
    }

    // 4. Inbound visitor contact inquiries matching rules
    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(request.resource.data);
      allow get, list, update, delete: if false; // Visitors cannot read or manipulate queries once posted
    }

    // 5. Testimonials matches
    match /testimonials/{testimonialId} {
      allow read, list: if true; // Public access
      allow create: if isSignedIn()
        && isValidId(testimonialId)
        && isValidTestimonial(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false; // Testimonials are unmodifiable for absolute truth integrity
    }
  }
}
